# Environment Configuration

# Database - Using SQLite for local development
DATABASE_URL=sqlite:///./moneymindset.db

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenRouter (OpenAI-compatible API)
OPENAI_API_KEY=sk-or-v1-your-openrouter-api-key
OPENAI_MODEL=openai/gpt-oss-120b:free
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Redis (optional)
REDIS_URL=redis://localhost:6379/0

# App
DEBUG=True

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Market Data APIs

NEWSAPI_KEY=your-newsapi-key

# Finnhub Configuration (US Markets)
FINNHUB_API_KEY=your-finnhub-api-key
FINNHUB_ENABLED=true

# Indian Stock Market API Configuration (Indian Markets)
INDIAN_MARKET_API_URL=https://stock.indianapi.in/
INDIAN_MARKET_API_KEY=your-indian-api-key
INDIAN_MARKET_ENABLED=true

# yfinance Fallback
YFINANCE_ENABLED=true
